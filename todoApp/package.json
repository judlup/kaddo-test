{
  "name": "todoapp",
  "version": "0.1.0",
  "description": "A simple CLI task manager built with Node.js, TypeScript, and SQLite",
  "type": "commonjs",
  "main": "dist/cli/index.js",
  "bin": {
    "todo": "dist/cli/index.js"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsx src/cli/index.ts --help",
    "start": "node dist/cli/index.js",
    "test": "vitest run",
    "test:run": "vitest run",
    "lint": "eslint src --ext .ts",
    "format": "prettier --write src"
  },
  "engines": {
    "node": ">=22"
  },
  "packageManager": "pnpm@9.15.4",
  "keywords": [
    "todo",
    "cli",
    "task-manager"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "commander": "^11.1.0",
    "better-sqlite3": "^9.2.2"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.8",
    "@types/node": "^20.10.6",
    "@typescript-eslint/eslint-plugin": "^6.17.0",
    "@typescript-eslint/parser": "^6.17.0",
    "eslint": "^8.56.0",
    "prettier": "^3.1.1",
    "typescript": "^5.3.3",
    "vitest": "^1.1.0",
    "tsx": "^4.7.0"
  }
}
